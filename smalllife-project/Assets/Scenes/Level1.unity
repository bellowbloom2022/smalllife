  m_Name: 
  m_EditorClassIdentifier: 
  data: 0
  entries:
  - Language: English
    Text: When I see "The Biking Grandpa" I record this little moment in my phone.
    Object: {fileID: 0}
  - Language: Chinese
    Text: "\u5F53\u6211\u770B\u5230\u201C\u515C\u98CE\u5927\u53D4\u201D\u65F6\uFF0C\u6211\u4F1A\u5728\u624B\u673A\u91CC\u8BB0\u5F55\u4E0B\u8FD9\u4E2A\u5C0F\u60C5\u8282\u3002"
    Object: {fileID: 0}
  - Language: Japanese
    Text: "\u300C\u30B5\u30A4\u30AF\u30EA\u30F3\u30B0\u304A\u3058\u3055\u3093\u300D\u3092\u898B\u304B\u3051\u305F\u3089\u3001\u305D\u306E\u5C0F\u3055\u306A\u51FA\u6765\u4E8B\u3092\u30B9\u30DE\u30DB\u306B\u8A18\u9332\u3059\u308B\u3002"
    Object: {fileID: 0}
