    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u65C5\u7A0B\uFF0C\u624D\u521A\u521A\u5F00\u59CB\u3002\n\u5728\u672A\u6765\u7684\u5B8C\u6574\u7248\u672C\u4E2D\uFF0C\u4F60\u5C06\u4F53\u9A8C\u5230\uFF1A\n\n\u2022
    100+\u4E2A\u53EF\u4EA4\u4E92\u7684\u7CBE\u5F69\u77AC\u95F4\n \u2022 20+\u4E2A\u53D6\u6750\u81EA\u771F\u5B9E\u4E0A\u6D77\u7684\u57CE\u5E02\u666F\u89C2\n\u2022
    \u66F4\u591A\u5173\u4E8E\u751F\u6D3B\u788E\u7247\u4E0E\u6E29\u6696\u76F8\u9047\u7684\u6545\u4E8B\n\n\u522B\u5FD8\u4E86\u5C06\u300A\u5C0F\u5C0F\u751F\u6D3B\uFF1A\u4E0A\u6D77\u7BC7\u300B\u52A0\u5165Steam\u613F\u671B\u5355\u3002"
